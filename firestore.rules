rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }


    function isOwner(userId) {
      return request.auth.uid == userId;
    }


    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }


    match /categories/{encodedId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        request.resource.data.count == resource.data.count + 1
      );
    }


    match /users/{userId}/flashcards/{cardId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || 
        resource.data.isPublic == true
      );
      allow write: if isAuthenticated() && isOwner(userId);
    }


    match /users/{userId}/{document=**} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }


    match /users/{userId}/worksheets/{worksheetId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }


    match /users/{userId}/stats/{document=**} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }


    match /vocabulary/{encodedWord} {
      allow read: if isAuthenticated();
      allow write: if false;  // Only admins can modify base vocabulary
    }


    match /vocabulary/{wordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.isPublic == true
      );
    }
  }
}