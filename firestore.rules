rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Add admin access to all collections
    match /{document=**} {
      allow read, write: if isAuthenticated() && isAdmin();
    }

    // User profiles and stats
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Categories collection at root level with proper encoding
    match /categories/{encodedId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        request.resource.data.count == resource.data.count + 1
      );
    }

    // User's personal flashcards as nested collection
    match /users/{userId}/flashcards/{cardId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || 
        resource.data.isPublic == true
      );
      allow create: if isAuthenticated() && isOwner(userId) && (
        request.resource.data.keys().hasAll(['word', 'englishDefinition', 'partOfSpeech']) &&
        request.resource.data.exampleSentence is string || request.resource.data.exampleSentence == null
      );
      allow update: if isAuthenticated() && isOwner(userId);
    }

    // User stats and progress stays under user doc
    match /users/{userId}/{document=**} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // Worksheets collection
    match /users/{userId}/worksheets/{worksheetId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // Add user collections permission
    match /users/{userId}/stats/{document=**} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // Shared vocabulary reference collection
    match /vocabulary/{encodedWord} {
      allow read: if isAuthenticated();
      allow write: if false;  // Only admins can modify base vocabulary
    }

    // Public vocabulary collection
    match /vocabulary/{wordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.isPublic == true
      );
    }

    match /users/{userId}/articles/{articleId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}